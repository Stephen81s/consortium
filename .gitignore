# FICHIER : consortium/.gitignore
# Fichiers et dossiers à ignorer dans un projet Next.js + Supabase

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Next.js ---
.next/
out/
dist/

# --- Environnement ---
.env
.env.local
.env.development.local
.env.production.local
.env.test.local

# --- Système ---
.DS_Store
Thumbs.db

# --- Logs ---
*.log

# --- Typescript ---
*.tsbuildinfo

# --- Supabase (local dev) ---
supabase/.temp/
supabase/.branches/